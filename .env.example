# Copy this file to `.env.local` and fill in your credentials.
# Never commit .env.local — it is in .gitignore.
#
# Quick setup:
# 1. Create `.env.local` in the project root.
# 2. Copy everything from this file into `.env.local`.
# 3. Replace the placeholder values below with real credentials.
# 4. Restart `npm run dev` after changing env values.

# OpenAI API key — used by the AI damage analysis route (/api/review)
# Create one here: https://platform.openai.com/api-keys
# Official help: https://help.openai.com/en/articles/4936850-where-do-i-find-my-openai-api-key
OPENAI_API_KEY=your-openai-api-key-here

# Optional: choose the OpenAI model used for review.
# Leave this as-is unless you know you want to change it.
OPENAI_MODEL=gpt-4.1-mini

# Sentinel Hub credentials — used by the satellite image generator (/api/satellite/generate)
# Sign up / log in: https://apps.sentinel-hub.com/dashboard/
# Create credentials in Dashboard -> User Settings -> OAuth clients.
# Official auth docs: https://docs.sentinel-hub.com/api/latest/api/overview/authentication/
SENTINELHUB_CLIENT_ID=your-sentinel-hub-client-id
SENTINELHUB_CLIENT_SECRET=your-sentinel-hub-client-secret
SENTINELHUB_BASE_URL=https://services.sentinel-hub.com
